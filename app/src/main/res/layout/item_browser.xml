<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#CCFFF8F6"
    app:strokeColor="#10FFFFFF"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="64dp"
        android:orientation="horizontal"
        android:paddingLeft="10dp"
        android:paddingTop="9dp"
        android:paddingRight="10dp"
        android:paddingBottom="9dp">

        <ImageView
            android:id="@+id/imageCover"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_music_note" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/ink"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/subtle"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/textMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:textColor="@color/seed"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/checkSelect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6dp"
            android:buttonTint="@color/seed"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/imageCached"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginLeft="8dp"
            android:src="@drawable/ic_cloud_cached"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/imageAction"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginLeft="10dp"
            android:background="@drawable/bg_glass_card"
            android:padding="4dp"
            android:src="@drawable/ic_playlist_add"
            android:tint="@color/seed"
            android:visibility="gone" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
