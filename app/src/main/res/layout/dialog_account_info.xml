<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardBackgroundColor="#F8F3F1"
    app:cardCornerRadius="28dp"
    app:strokeColor="#12FFFFFF"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="你的音乐宇宙"
            android:textColor="@color/subtle"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/textAccountTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="账户信息"
            android:textColor="@color/ink"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textAccountSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="当前登录状态和本地缓存概览。"
            android:textColor="@color/subtle"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical">

            <TextView android:id="@+id/textAccountNameValue" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_glass_card" android:padding="14dp" android:textColor="@color/ink" android:textSize="14sp" />
            <TextView android:id="@+id/textAccountHostValue" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_glass_card" android:padding="14dp" android:textColor="@color/ink" android:textSize="14sp" />
            <TextView android:id="@+id/textAccountSidValue" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_glass_card" android:padding="14dp" android:textColor="@color/ink" android:textSize="14sp" />
            <TextView android:id="@+id/textAccountCacheValue" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_glass_card" android:padding="14dp" android:textColor="@color/ink" android:textSize="14sp" />
            <TextView android:id="@+id/textAccountHistoryValue" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_glass_card" android:padding="14dp" android:textColor="@color/ink" android:textSize="14sp" />
            <TextView android:id="@+id/textAccountRememberValue" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_glass_card" android:padding="14dp" android:textColor="@color/ink" android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:gravity="end" android:orientation="horizontal">
            <TextView android:id="@+id/buttonAccountClose" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_button" android:paddingLeft="18dp" android:paddingTop="10dp" android:paddingRight="18dp" android:paddingBottom="10dp" android:text="关闭" android:textColor="@android:color/white" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
