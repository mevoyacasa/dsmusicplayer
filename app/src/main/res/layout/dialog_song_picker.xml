<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardBackgroundColor="#F8F3F1"
    app:cardCornerRadius="28dp"
    app:strokeColor="#12FFFFFF"
    app:strokeWidth="1dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_gradient" android:orientation="vertical" android:padding="22dp">
        <TextView android:id="@+id/textPickerTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/ink" android:textSize="26sp" android:textStyle="bold" />
        <TextView android:id="@+id/textPickerSubtitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:textColor="@color/subtle" android:textSize="14sp" />
        <EditText android:id="@+id/editPickerSearch" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:background="@drawable/bg_glass_card" android:hint="搜索歌名、歌手或专辑" android:paddingLeft="16dp" android:paddingTop="14dp" android:paddingRight="16dp" android:paddingBottom="14dp" android:textColor="@color/ink" android:textColorHint="@color/subtle" />
        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:scrollbars="none">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:id="@+id/buttonSortName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_button" android:paddingLeft="14dp" android:paddingTop="8dp" android:paddingRight="14dp" android:paddingBottom="8dp" android:text="名称" android:textColor="@android:color/white" android:textSize="13sp" android:textStyle="bold" />
                <TextView android:id="@+id/buttonSortDuration" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:background="@drawable/bg_chip_soft" android:paddingLeft="14dp" android:paddingTop="8dp" android:paddingRight="14dp" android:paddingBottom="8dp" android:text="时长" android:textColor="@color/seed" android:textSize="13sp" android:textStyle="bold" />
                <TextView android:id="@+id/buttonSortArtist" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:background="@drawable/bg_chip_soft" android:paddingLeft="14dp" android:paddingTop="8dp" android:paddingRight="14dp" android:paddingBottom="8dp" android:text="歌手" android:textColor="@color/seed" android:textSize="13sp" android:textStyle="bold" />
                <TextView android:id="@+id/buttonPickerSelectAll" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:background="@drawable/bg_chip_soft" android:paddingLeft="14dp" android:paddingTop="8dp" android:paddingRight="14dp" android:paddingBottom="8dp" android:text="全选" android:textColor="@color/seed" android:textSize="13sp" android:textStyle="bold" />
            </LinearLayout>
        </HorizontalScrollView>
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerPicker" android:layout_width="match_parent" android:layout_height="360dp" android:layout_marginTop="16dp" android:clipToPadding="false" android:paddingBottom="8dp" android:scrollbars="vertical" app:fastScrollEnabled="true" app:fastScrollVerticalThumbDrawable="@drawable/fastscroll_thumb" app:fastScrollVerticalTrackDrawable="@drawable/fastscroll_track" app:fastScrollHorizontalThumbDrawable="@drawable/fastscroll_thumb" app:fastScrollHorizontalTrackDrawable="@drawable/fastscroll_track" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="end" android:orientation="horizontal">
            <TextView android:id="@+id/buttonPickerCancel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_chip_soft" android:paddingLeft="16dp" android:paddingTop="10dp" android:paddingRight="16dp" android:paddingBottom="10dp" android:text="取消" android:textColor="@color/subtle" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:id="@+id/buttonPickerExtra" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="10dp" android:background="@drawable/bg_chip_soft" android:paddingLeft="16dp" android:paddingTop="10dp" android:paddingRight="16dp" android:paddingBottom="10dp" android:text="添加歌曲" android:textColor="@color/seed" android:textSize="14sp" android:textStyle="bold" android:visibility="gone" />
            <TextView android:id="@+id/buttonPickerConfirm" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="10dp" android:background="@drawable/bg_button" android:paddingLeft="18dp" android:paddingTop="10dp" android:paddingRight="18dp" android:paddingBottom="10dp" android:textColor="@android:color/white" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
